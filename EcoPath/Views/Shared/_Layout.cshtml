<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0A0F1C" />
    <title>@ViewData["Title"] - EcoPath</title>
    <script type="importmap"></script>

    @* ── Google Fonts: Plus Jakarta Sans + Inter + Space Grotesk + JetBrains Mono ── *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

    @* ── Design System CSS Stack ── *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/animations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EcoPath.styles.css" asp-append-version="true" />

    @* ── Inline Critical: Theme Initialization (prevents flash) ── *@
    <script>
        (function() {
            const saved = localStorage.getItem('ecopath-theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            const theme = saved || (prefersDark ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
</head>
<body>
    @* ── Leaf Particle Background (subtle floating leaves) ── *@
    <div class="eco-leaf-particles" aria-hidden="true">
        <div class="eco-leaf"></div>
        <div class="eco-leaf"></div>
        <div class="eco-leaf"></div>
        <div class="eco-leaf"></div>
        <div class="eco-leaf"></div>
    </div>

    @* ── SVG Gradient Definitions (used by eco score ring, etc.) ── *@
    <svg width="0" height="0" style="position:absolute">
        <defs>
            <linearGradient id="ecoScoreGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#10B981" />
                <stop offset="50%" stop-color="#0D9488" />
                <stop offset="100%" stop-color="#06B6D4" />
            </linearGradient>
        </defs>
    </svg>

    <header>
        <nav class="eco-navbar navbar navbar-expand-lg navbar-toggleable-lg">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/EcoPathLogo.png" alt="EcoPath" class="navbar-logo" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-lg-3">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-2"></i><span>Acasă</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-speedometer2 me-2"></i><span>Dashboard</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Trip" asp-action="History">
                                <i class="bi bi-clock-history me-2"></i><span>Istoric</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Map">
                                <i class="bi bi-map me-2"></i><span>Hartă Eco</span>
                            </a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        @* ── Dark Mode Toggle ── *@
                        <button class="eco-theme-toggle" id="themeToggle" type="button" aria-label="Toggle dark mode" title="Comută tema">
                            <i class="bi bi-moon-stars" id="themeIcon"></i>
                        </button>
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="eco-footer">
        <div class="container text-center">
            &copy; 2026 - <strong>EcoPath</strong> — <a asp-area="" asp-controller="Home" asp-action="Privacy">Confidențialitate</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
