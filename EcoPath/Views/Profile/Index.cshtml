@model EcoPath.Models.ApplicationUser
@{
    ViewData["Title"] = "Profilul Meu";
}

<link rel="stylesheet" href="~/css/profile.css" />

<div class="container py-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Profile Header -->
    <div class="profile-header">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1><i class="bi bi-person-circle me-2"></i>Profilul Meu</h1>
                <p>Gestionează informațiile tale personale</p>
            </div>
            <a asp-action="Edit" class="profile-edit-btn">
                <i class="bi bi-pencil-square"></i>Editează Profilul
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Personal Information Card -->
        <div class="col-lg-6">
            <div class="profile-card h-100">
                <div class="profile-card-header header-eco">
                    <i class="bi bi-person-lines-fill"></i>Informații Personale
                </div>
                <div class="profile-card-body">
                    <div class="profile-info-row">
                        <label>Adresă Email</label>
                        <div class="info-value">
                            <i class="bi bi-envelope"></i>@Model.Email
                        </div>
                    </div>
                    <div class="profile-info-row">
                        <label>Nume utilizator</label>
                        <div class="info-value">
                            <i class="bi bi-person-badge"></i>@Model.UserName
                        </div>
                    </div>
                    <div class="profile-info-row">
                        <label>Oraș</label>
                        <div class="info-value">
                            <i class="bi bi-geo-alt-fill"></i>
                            @(string.IsNullOrEmpty(Model.City) ? "Neconfigurat" : Model.City)
                        </div>
                    </div>
                    <div class="profile-info-row">
                        <label>Greutate</label>
                        <div class="info-value">
                            <i class="bi bi-heart-pulse"></i>
                            @(Model.Weight > 0 ? $"{Model.Weight} kg" : "Neconfigurat")
                        </div>
                    </div>
                    <div class="profile-info-row">
                        <label>Telefon</label>
                        <div class="info-value">
                            <i class="bi bi-telephone"></i>
                            @(string.IsNullOrEmpty(Model.PhoneNumber) ? "Neconfigurat" : Model.PhoneNumber)
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Card -->
        <div class="col-lg-6">
            <div class="profile-card h-100">
                <div class="profile-card-header header-stats">
                    <i class="bi bi-graph-up"></i>Statistici Generale
                </div>
                <div class="profile-card-body">
                    @if (Model.Stats != null)
                    {
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="profile-stat-box stat-distance">
                                    <i class="bi bi-geo-alt-fill stat-icon"></i>
                                    <div class="stat-number">@Model.Stats.TotalDistance.ToString("N1")</div>
                                    <div class="stat-label">km parcurși</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="profile-stat-box stat-trips">
                                    <i class="bi bi-bicycle stat-icon"></i>
                                    <div class="stat-number">@Model.Stats.TotalTrips</div>
                                    <div class="stat-label">călătorii</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="profile-stat-box stat-co2">
                                    <i class="bi bi-clouds stat-icon"></i>
                                    <div class="stat-number">@Model.Stats.TotalCo2Saved.ToString("N1")</div>
                                    <div class="stat-label">kg CO₂ salvat</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="profile-stat-box stat-calories">
                                    <i class="bi bi-fire stat-icon"></i>
                                    <div class="stat-number">@Model.Stats.TotalCaloriesBurned.ToString("N0")</div>
                                    <div class="stat-label">calorii arse</div>
                                </div>
                            </div>
                        </div>
                        <div class="mt-3 text-center">
                            <span class="profile-updated">
                                <i class="bi bi-clock-history me-1"></i>
                                Actualizat: @Model.Stats.LastUpdated.ToString("dd MMMM yyyy, HH:mm")
                            </span>
                        </div>
                    }
                    else
                    {
                        <div class="profile-empty">
                            <i class="bi bi-bar-chart"></i>
                            <p>Statisticile vor fi disponibile după prima călătorie</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Achievements Section -->
        <div class="col-12">
            <div class="profile-card">
                <div class="profile-card-header header-achievements">
                    <i class="bi bi-trophy-fill"></i>Realizări Deblocate (@Model.Achievements.Count)
                </div>
                <div class="profile-card-body">
                    @if (Model.Achievements.Any())
                    {
                        <div class="row g-3">
                            @foreach (var achievement in Model.Achievements.OrderByDescending(a => a.UnlockedAt))
                            {
                                <div class="col-md-6 col-lg-4">
                                    <div class="profile-achievement h-100">
                                        <div class="ach-icon">
                                            <i class="@achievement.Icon"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h6>@achievement.Name</h6>
                                            <p class="ach-desc">@achievement.Description</p>
                                            <span class="ach-date">
                                                <i class="bi bi-calendar-check me-1"></i>
                                                @achievement.UnlockedAt.ToString("dd MMM yyyy")
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="profile-empty">
                            <i class="bi bi-trophy"></i>
                            <p>Nu ai deblocat încă nicio realizare</p>
                            <p>Începe să călătorești eco pentru a debloca badge-uri!</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Trips Section -->
        <div class="col-12">
            <div class="profile-card">
                <div class="profile-card-header header-trips">
                    <div class="d-flex justify-content-between align-items-center w-100">
                        <span class="d-flex align-items-center gap-2">
                            <i class="bi bi-clock-history"></i>Călătorii Recente
                        </span>
                        <a href="#" class="profile-edit-btn" style="padding: 0.35rem 0.75rem; font-size: 0.75rem;">Vezi Toate</a>
                    </div>
                </div>
                <div class="profile-card-body">
                    @if (Model.Trips.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover profile-table">
                                <thead>
                                    <tr>
                                        <th>Traseu</th>
                                        <th>Transport</th>
                                        <th>Distanță</th>
                                        <th>CO₂ Salvat</th>
                                        <th>Data</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var trip in Model.Trips)
                                    {
                                        <tr>
                                            <td>
                                                <i class="bi bi-geo-fill text-success me-1"></i>
                                                @trip.StartLocation → @trip.EndLocation
                                            </td>
                                            <td>
                                                @switch (trip.TransportType)
                                                {
                                                    case TransportType.Walking:
                                                        <span class="badge bg-success"><i class="bi bi-person-walking me-1"></i>Mers pe jos</span>
                                                        break;
                                                    case TransportType.Biking:
                                                        <span class="badge bg-primary"><i class="bi bi-bicycle me-1"></i>Bicicletă</span>
                                                        break;
                                                    case TransportType.Bus:
                                                        <span class="badge bg-info"><i class="bi bi-bus-front me-1"></i>Autobuz</span>
                                                        break;
                                                    case TransportType.Tram:
                                                        <span class="badge bg-info"><i class="bi bi-train-front me-1"></i>Tramvai</span>
                                                        break;
                                                    case TransportType.Metro:
                                                        <span class="badge bg-info"><i class="bi bi-subway me-1"></i>Metro</span>
                                                        break;
                                                    case TransportType.Car:
                                                        <span class="badge bg-secondary"><i class="bi bi-car-front me-1"></i>Mașină</span>
                                                        break;
                                                }
                                            </td>
                                            <td class="fw-bold">@trip.Distance.ToString("N2") km</td>
                                            <td class="text-success fw-bold">@trip.Co2Saved.ToString("N2") kg</td>
                                            <td>@trip.StartTime.ToString("dd MMM yyyy")</td>
                                            <td>
                                                @if (trip.IsVerified)
                                                {
                                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Verificat</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary"><i class="bi bi-clock me-1"></i>În așteptare</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="profile-empty">
                            <i class="bi bi-map"></i>
                            <p>Nu ai înregistrat încă nicio călătorie</p>
                            <a href="#" class="btn btn-success">Adaugă Prima Călătorie</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
