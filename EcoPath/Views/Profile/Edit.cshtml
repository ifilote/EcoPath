@model EcoPath.Controllers.ProfileEditViewModel
@{
    ViewData["Title"] = "Editează Profilul";
}

<link rel="stylesheet" href="~/css/profile.css" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Header -->
            <div class="profile-header" style="padding: var(--space-6) var(--space-7); margin-bottom: var(--space-5);">
                <h1 style="font-size: var(--text-h2);"><i class="bi bi-pencil-square me-2"></i>Editează Profilul</h1>
                <p>Actualizează informațiile tale personale</p>
            </div>

            <!-- Edit Form Card -->
            <div class="profile-card">
                <div class="profile-card-header header-eco">
                    <i class="bi bi-person-gear"></i>Informații Personale
                </div>
                <div class="profile-card-body profile-form">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <!-- UserName -->
                        <div class="mb-4">
                            <label asp-for="UserName" class="form-label fw-semibold">
                                <i class="bi bi-person-badge text-success me-2"></i>Nume utilizator
                            </label>
                            <input asp-for="UserName" class="form-control form-control-lg" placeholder="Introdu numele de utilizator" />
                            <span asp-validation-for="UserName" class="text-danger"></span>
                            <div class="form-text">
                                <i class="bi bi-lightbulb me-1"></i>
                                Acest nume va fi vizibil public în clasamente și statistici
                            </div>
                        </div>

                        <!-- Email (Read Only) -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-envelope text-success me-2"></i>Adresă Email
                            </label>
                            <input asp-for="Email" class="form-control form-control-lg" readonly />
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>
                                Email-ul nu poate fi modificat din această pagină
                            </div>
                        </div>

                        <!-- City -->
                        <div class="mb-4">
                            <label asp-for="City" class="form-label fw-semibold">
                                <i class="bi bi-geo-alt-fill text-success me-2"></i>Oraș
                            </label>
                            <input asp-for="City" class="form-control form-control-lg" placeholder="Introdu orașul tău" />
                            <span asp-validation-for="City" class="text-danger"></span>
                            <div class="form-text">
                                <i class="bi bi-lightbulb me-1"></i>
                                Ne ajută să îți oferim informații relevante despre sesiuni locale
                            </div>
                        </div>

                        <!-- Weight -->
                        <div class="mb-4">
                            <label asp-for="Weight" class="form-label fw-semibold">
                                <i class="bi bi-heart-pulse text-success me-2"></i>Greutate (kg)
                            </label>
                            <input asp-for="Weight" type="number" step="0.1" class="form-control form-control-lg" 
                                   placeholder="Ex: 70.5" min="0" max="300" />
                            <span asp-validation-for="Weight" class="text-danger"></span>
                            <div class="form-text">
                                <i class="bi bi-lock me-1"></i>
                                Folosit pentru calculul caloriilor arse - aceste date rămân private
                            </div>
                        </div>

                        <!-- Phone Number -->
                        <div class="mb-4">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">
                                <i class="bi bi-telephone text-success me-2"></i>Număr de Telefon
                            </label>
                            <input asp-for="PhoneNumber" type="tel" class="form-control form-control-lg" 
                                   placeholder="Ex: +40712345678" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            <div class="form-text">
                                <i class="bi bi-shield-check me-1"></i>
                                Optional - pentru notificări și recuperare cont
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-between mt-5">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5">
                                <i class="bi bi-x-circle me-2"></i>Anulează
                            </a>
                            <button type="submit" class="btn btn-success btn-lg px-5">
                                <i class="bi bi-check-circle me-2"></i>Salvează Modificările
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Info Box -->
            <div class="profile-card mt-4" style="border-left: 4px solid var(--eco-secondary-500, #0EA5E9);">
                <div class="profile-card-body">
                    <div class="d-flex gap-3">
                        <div>
                            <i class="bi bi-info-circle-fill" style="font-size: 1.5rem; color: var(--eco-secondary-500, #0EA5E9);"></i>
                        </div>
                        <div>
                            <h6 style="font-family: var(--font-display); font-weight: var(--weight-bold); margin-bottom: var(--space-2);">Confidențialitate și Securitate</h6>
                            <p style="font-size: var(--text-body-sm); color: var(--color-text-muted); margin: 0; line-height: var(--leading-relaxed);">
                                Toate datele tale personale sunt securizate și criptate. Greutatea și alte informații sensibile 
                                sunt folosite doar pentru calcularea statisticilor personale și nu sunt partajate cu terțe părți.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tips Card -->
            <div class="profile-card mt-4" style="border-left: 4px solid var(--eco-primary-500);">
                <div class="profile-card-body">
                    <h6 style="font-family: var(--font-display); font-weight: var(--weight-bold); color: var(--eco-primary-600); margin-bottom: var(--space-2);">
                        <i class="bi bi-lightbulb-fill me-2"></i>Sfaturi pentru un profil complet
                    </h6>
                    <ul style="margin: 0; font-size: var(--text-body-sm); color: var(--color-text-muted); padding-left: 1.25rem;">
                        <li>Adaugă orașul pentru a primi recomandări de rute locale</li>
                        <li>Configurează greutatea pentru statistici precise de calorii</li>
                        <li>Adaugă numărul de telefon pentru securitate suplimentară</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // Add form validation feedback
        (function () {
            'use strict'
            var forms = document.querySelectorAll('form')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}
