@{
    ViewData["Title"] = "EcoPath — Călătorește Sustenabil";
}

<style>
    /* ═══════ HERO SECTION ═══════ */
    .eco-hero {
        min-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        padding: var(--space-8) 0;
    }

    .eco-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(ellipse at 20% 50%, rgba(16, 185, 129, 0.12) 0%, transparent 50%),
            radial-gradient(ellipse at 80% 20%, rgba(14, 165, 233, 0.08) 0%, transparent 50%),
            radial-gradient(ellipse at 50% 80%, rgba(139, 92, 246, 0.06) 0%, transparent 50%);
        pointer-events: none;
        z-index: 0;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
        padding: 0 var(--space-5);
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.2);
        border-radius: var(--radius-full);
        padding: var(--space-2) var(--space-4);
        font-family: var(--font-display);
        font-size: var(--text-caption);
        font-weight: var(--weight-semibold);
        color: var(--eco-primary-600);
        margin-bottom: var(--space-5);
        animation: fadeInUp 0.6s ease forwards;
    }

    [data-theme="dark"] .hero-badge {
        background: rgba(16, 185, 129, 0.08);
        border-color: rgba(16, 185, 129, 0.15);
        color: var(--eco-primary-400);
    }

    .hero-badge .pulse-dot {
        width: 8px;
        height: 8px;
        background: var(--eco-primary-500);
        border-radius: 50%;
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.3); }
    }

    .hero-title {
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: var(--weight-extrabold);
        letter-spacing: var(--tracking-tighter);
        line-height: 1.05;
        color: var(--color-text);
        margin-bottom: var(--space-5);
        animation: fadeInUp 0.6s ease 0.1s forwards;
        opacity: 0;
    }

    .hero-title .gradient-text {
        background: linear-gradient(135deg, var(--eco-primary-500) 0%, #0D9488 40%, #0EA5E9 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-subtitle {
        font-family: var(--font-body);
        font-size: clamp(1rem, 2vw, 1.25rem);
        color: var(--color-text-muted);
        line-height: var(--leading-relaxed);
        max-width: 600px;
        margin: 0 auto var(--space-7);
        animation: fadeInUp 0.6s ease 0.2s forwards;
        opacity: 0;
    }

    .hero-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-4);
        flex-wrap: wrap;
        animation: fadeInUp 0.6s ease 0.3s forwards;
        opacity: 0;
    }

    .hero-btn-primary {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        background: linear-gradient(135deg, var(--eco-primary-600) 0%, var(--eco-primary-500) 50%, #0D9488 100%);
        color: white;
        padding: var(--space-4) var(--space-7);
        border-radius: var(--radius-lg);
        font-family: var(--font-display);
        font-weight: var(--weight-bold);
        font-size: var(--text-body);
        text-decoration: none;
        border: none;
        transition: all 0.3s var(--ease-out);
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
    }

    .hero-btn-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 30px rgba(16, 185, 129, 0.4);
        color: white;
    }

    .hero-btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        background: transparent;
        color: var(--color-text);
        padding: var(--space-4) var(--space-7);
        border-radius: var(--radius-lg);
        font-family: var(--font-display);
        font-weight: var(--weight-semibold);
        font-size: var(--text-body);
        text-decoration: none;
        border: 2px solid rgba(0, 0, 0, 0.1);
        transition: all 0.3s var(--ease-out);
    }

    [data-theme="dark"] .hero-btn-secondary {
        border-color: rgba(255, 255, 255, 0.12);
    }

    .hero-btn-secondary:hover {
        background: rgba(16, 185, 129, 0.05);
        border-color: var(--eco-primary-300);
        color: var(--eco-primary-600);
        transform: translateY(-2px);
    }

    /* ═══════ FEATURE CARDS ═══════ */
    .features-section {
        padding: var(--space-10) 0 var(--space-12);
    }

    .features-label {
        display: block;
        font-family: var(--font-display);
        font-size: var(--text-caption);
        font-weight: var(--weight-bold);
        text-transform: uppercase;
        letter-spacing: var(--tracking-widest);
        color: var(--eco-primary-500);
        text-align: center;
        margin-bottom: var(--space-2);
    }

    .features-heading {
        font-family: var(--font-display);
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        font-weight: var(--weight-extrabold);
        letter-spacing: var(--tracking-tight);
        color: var(--color-text);
        text-align: center;
        margin-bottom: var(--space-3);
    }

    .features-subtext {
        font-size: var(--text-body-lg);
        color: var(--color-text-muted);
        text-align: center;
        max-width: 550px;
        margin: 0 auto var(--space-9);
    }

    .feature-card {
        background: var(--glass-white-10, rgba(255, 255, 255, 0.85));
        backdrop-filter: blur(20px);
        border-radius: var(--radius-xl);
        padding: var(--space-7);
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow: var(--shadow-md);
        transition: all 0.4s var(--ease-out);
        text-align: center;
        height: 100%;
        position: relative;
        overflow: hidden;
    }

    [data-theme="dark"] .feature-card {
        background: rgba(17, 24, 39, 0.7);
        border-color: rgba(255, 255, 255, 0.06);
    }

    .feature-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-xl);
    }

    .feature-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    }

    .feature-card.card-green::before {
        background: linear-gradient(90deg, var(--eco-primary-500), #34D399);
    }
    .feature-card.card-blue::before {
        background: linear-gradient(90deg, #3B82F6, #60A5FA);
    }
    .feature-card.card-purple::before {
        background: linear-gradient(90deg, #8B5CF6, #A78BFA);
    }
    .feature-card.card-orange::before {
        background: linear-gradient(90deg, #F59E0B, #FBBF24);
    }

    .feature-icon {
        width: 64px;
        height: 64px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        margin: 0 auto var(--space-4);
    }

    .card-green .feature-icon { background: rgba(16, 185, 129, 0.12); color: var(--eco-primary-500); }
    .card-blue .feature-icon { background: rgba(59, 130, 246, 0.12); color: #3B82F6; }
    .card-purple .feature-icon { background: rgba(139, 92, 246, 0.12); color: #8B5CF6; }
    .card-orange .feature-icon { background: rgba(245, 158, 11, 0.12); color: #F59E0B; }

    .feature-card h3 {
        font-family: var(--font-display);
        font-size: var(--text-body-lg);
        font-weight: var(--weight-bold);
        color: var(--color-text);
        margin-bottom: var(--space-2);
    }

    .feature-card p {
        font-size: var(--text-body-sm);
        color: var(--color-text-muted);
        line-height: var(--leading-relaxed);
        margin: 0;
    }

    /* ═══════ STATS BAR ═══════ */
    .stats-bar {
        background: linear-gradient(135deg, var(--eco-primary-900) 0%, var(--eco-primary-700) 50%, #0D9488 100%);
        border-radius: var(--radius-xl);
        padding: var(--space-7) var(--space-5);
        color: white;
        position: relative;
        overflow: hidden;
    }

    .stats-bar::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 50% 0%, rgba(255,255,255,0.1) 0%, transparent 60%);
        pointer-events: none;
    }

    .stat-item {
        text-align: center;
        position: relative;
        z-index: 1;
    }

    .stat-item .stat-val {
        font-family: var(--font-data);
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        font-weight: var(--weight-extrabold);
        letter-spacing: var(--tracking-tighter);
        line-height: var(--leading-none);
        margin-bottom: var(--space-1);
        font-variant-numeric: tabular-nums;
    }

    .stat-item .stat-lbl {
        font-size: var(--text-body-sm);
        opacity: 0.8;
        font-weight: var(--weight-medium);
    }

    /* ═══════ CTA ═══════ */
    .cta-section {
        text-align: center;
        padding: var(--space-12) 0 var(--space-10);
    }

    .cta-section h2 {
        font-family: var(--font-display);
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: var(--weight-extrabold);
        letter-spacing: var(--tracking-tight);
        color: var(--color-text);
        margin-bottom: var(--space-3);
    }

    .cta-section p {
        font-size: var(--text-body-lg);
        color: var(--color-text-muted);
        margin-bottom: var(--space-6);
    }

    /* ═══════ ANIMATIONS ═══════ */
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(24px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .animate-on-scroll {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .animate-on-scroll.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<!-- ═══════ WEATHER MOTIVATIONAL HERO (Authenticated Only) ═══════ -->
@if (User.Identity?.IsAuthenticated == true)
{
    <link rel="stylesheet" href="~/css/weather.css" asp-append-version="true" />
    <section class="container" style="padding-top: var(--space-6, 1.5rem);">
        <div class="weather-hero loading" id="weather-hero">
            @* Content rendered dynamically by weather.js *@
        </div>
    </section>
}

<!-- ═══════ HERO ═══════ -->
<section class="eco-hero">
    <div class="hero-content">
        <div class="hero-badge">
            <span class="pulse-dot"></span>
            Platforma eco-travel #1 din România
        </div>
        <h1 class="hero-title">
            Fiecare pas contează.<br>
            <span class="gradient-text">Călătorește sustenabil.</span>
        </h1>
        <p class="hero-subtitle">
            Urmărește călătoriile tale eco, monitorizează CO₂ salvat, calorii arse și 
            impactul tău asupra mediului. Transformă fiecare drum într-o acțiune verde.
        </p>
        <div class="hero-actions">
            <a asp-area="Identity" asp-page="/Account/Register" class="hero-btn-primary">
                <i class="bi bi-rocket-takeoff"></i>Începe Gratuit
            </a>
            <a asp-controller="Dashboard" asp-action="Index" class="hero-btn-secondary">
                <i class="bi bi-grid-1x2"></i>Vezi Dashboard
            </a>
        </div>
    </div>
</section>

<!-- ═══════ FEATURES ═══════ -->
<section class="features-section">
    <div class="container">
        <span class="features-label">De ce EcoPath?</span>
        <h2 class="features-heading">Totul într-un singur loc</h2>
        <p class="features-subtext">Monitorizare inteligentă, gamificată și frumoasă pentru impactul tău ecologic</p>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3 animate-on-scroll">
                <div class="feature-card card-green">
                    <div class="feature-icon"><i class="bi bi-cloud-sun"></i></div>
                    <h3>CO₂ Salvat</h3>
                    <p>Monitorizează în timp real cât dioxid de carbon economisești cu fiecare călătorie eco.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 animate-on-scroll">
                <div class="feature-card card-blue">
                    <div class="feature-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <h3>Statistici Detaliate</h3>
                    <p>Dashboard interactiv cu grafice, heatmap-uri și comparații săptămânale.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 animate-on-scroll">
                <div class="feature-card card-purple">
                    <div class="feature-icon"><i class="bi bi-trophy"></i></div>
                    <h3>Realizări & Badge-uri</h3>
                    <p>Deblochează realizări, urcă în clasament și concurează cu alți eco-călători.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 animate-on-scroll">
                <div class="feature-card card-orange">
                    <div class="feature-icon"><i class="bi bi-fire"></i></div>
                    <h3>Calorii Arse</h3>
                    <p>Fii sănătos în timp ce salvezi planeta. Monitorizarea caloriilor incluse.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════ STATS BAR ═══════ -->
<section class="container mb-5 animate-on-scroll">
    <div class="stats-bar">
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-val">12K+</div>
                    <div class="stat-lbl">Călătorii Eco</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-val">4.8t</div>
                    <div class="stat-lbl">CO₂ Economisit</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-val">850+</div>
                    <div class="stat-lbl">Utilizatori Activi</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-val">98%</div>
                    <div class="stat-lbl">Satisfacție</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════ CTA ═══════ -->
<section class="cta-section container animate-on-scroll">
    <h2>Gata să faci diferența?</h2>
    <p>Alătură-te comunității EcoPath și transformă fiecare călătorie într-un act de eco-responsabilitate.</p>
    <a asp-area="Identity" asp-page="/Account/Register" class="hero-btn-primary">
        <i class="bi bi-leaf"></i>Creează Cont Gratuit
    </a>
</section>

@if (User.Identity?.IsAuthenticated == true)
{
    <script src="~/js/weather.js" asp-append-version="true"></script>
}

<script>
    // Scroll-triggered animations for home page
    document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry, index) => {
                if (entry.isIntersecting) {
                    setTimeout(() => {
                        entry.target.classList.add('visible');
                    }, index * 100);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15 });

        document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
    });
</script>