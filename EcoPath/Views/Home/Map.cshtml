@model EcoPath.Models.MapViewModel

@{
    ViewData["Title"] = "Explorare Eco";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* ── Dedicated stylesheet for the map page ── *@
<link rel="stylesheet" href="~/css/eco-map.css" asp-append-version="true" />

@* Add a body class for full-screen map styling overrides *@
<script>document.body.classList.add('eco-map-page');</script>

<div id="map-container">

    @* ── Loading Overlay (shown while detecting location) ── *@
    <div id="map-loader">
        <div class="eco-spinner"></div>
        <span>Se detectează locația ta...</span>
    </div>

    @* ── The Google Map Canvas ── *@
    <div id="map"></div>

    @* ── Location Status Toast ── *@
    <div id="location-status" class="eco-location-status"></div>

    @* ── "Locate Me" floating button (bottom-right) ── *@
    <button id="locate-me-btn" title="Mergi la locația mea">
        <i class="bi bi-crosshair"></i>
    </button>

    @* ── Toggle Button (shown when panel is minimized) ── *@
    <button id="toggle-panel-btn" onclick="togglePanel(true)" title="Deschide planificatorul">
        <i class="bi bi-search fs-4" style="color: var(--map-accent, #10B981);"></i>
    </button>

    @* ═══════════════════════════════════════════════════════
       ── Floating Side Panel — Route planner
    ═══════════════════════════════════════════════════════ *@
    <div class="eco-panel" id="main-panel">

        @* ── Panel Header ── *@
        <div class="eco-panel__header">
            <h4 class="eco-panel__title">Planificator Eco</h4>
            <button class="eco-panel__close" onclick="togglePanel(false)" title="Minimizează">
                <i class="bi bi-chevron-left"></i>
            </button>
        </div>

        <div class="eco-panel__body">

            @* ── Start Location (auto-detected, read-only style) ── *@
            <div>
                <label class="eco-field-label">PLECARE (locația ta)</label>
                <div class="eco-start-indicator">
                    <i class="bi bi-record-circle"></i>
                    <input type="text" id="start-input" readonly placeholder="Se detectează locația..." />
                </div>
            </div>

            @* ── Destination Input with Autocomplete ── *@
            <div>
                <label class="eco-field-label">DESTINAȚIE</label>
                <div class="eco-input-group">
                    <div class="eco-input-icon">
                        <i class="bi bi-geo-fill" style="color: var(--map-red, #EF4444);"></i>
                    </div>
                    <input type="text"
                           id="dest-input"
                           placeholder="Caută adresă sau click pe hartă..." />
                </div>
            </div>

            @* ── Transport Mode Selector ── *@
            <div class="eco-transport-bar">
                <button class="transport-btn active" data-mode="DRIVING" title="Mașină">
                    <i class="bi bi-car-front"></i>
                    <span class="btn-label">Auto</span>
                </button>
                <button class="transport-btn" data-mode="TRANSIT" title="Transport public">
                    <i class="bi bi-bus-front"></i>
                    <span class="btn-label">Bus</span>
                </button>
                <button class="transport-btn" data-mode="BICYCLING" title="Bicicletă">
                    <i class="bi bi-bicycle"></i>
                    <span class="btn-label">Bici</span>
                </button>
                <button class="transport-btn" data-mode="WALKING" title="Pe jos">
                    <i class="bi bi-person-walking"></i>
                    <span class="btn-label">Walk</span>
                </button>
            </div>

            @* ── Route Results ── *@
            <div id="results-container" class="eco-results eco-hidden">
                <div class="eco-results__title">Variante disponibile</div>
                <div id="results-content"></div>
                <div id="eco-suggestion-container"></div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    @* ── Load eco-map.js BEFORE the Maps API so the IIFE builds the module ── *@
    <script src="~/js/eco-map.js" asp-append-version="true"></script>

    @* ── Google Maps JavaScript API with Places library ──
         The "callback=initEcoMap" triggers our init function once loaded.
         API Key is injected from appsettings via the ViewModel. ── *@
    <script async
            src="https://maps.googleapis.com/maps/api/js?key=@Model.GoogleMapsApiKey&libraries=places&callback=initEcoMap&loading=async">
    </script>
}