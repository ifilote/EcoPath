@page
@model EcoPath.Pages.Trip.RecommendModel
@{
    ViewData["Title"] = "Get Transport Recommendation";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="mb-4"><i class="bi bi-compass"></i> Transport Recommendation</h1>

            <form method="post" class="card p-4">
                <div class="mb-3">
                    <label asp-for="Distance" class="form-label">Distance (km)</label>
                    <input asp-for="Distance" type="number" step="0.1" min="0.1" max="100" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label asp-for="Hour" class="form-label">Time (Hour)</label>
                    <input asp-for="Hour" type="number" min="0" max="23" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="TimeSensitivity" class="form-label">
                        Time Sensitivity (1=Eco, 10=Speed)
                    </label>
                    <input asp-for="TimeSensitivity" type="range" min="1" max="10" class="form-range" />
                    <small class="text-muted">Current: @Model.TimeSensitivity</small>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100">
                    <i class="bi bi-search"></i> Get Recommendation
                </button>
            </form>

            @if (Model.Recommendation != null)
            {
                <div class="card mt-4 border-success">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-check-circle-fill text-success"></i>
                            Recommended: <strong>@Model.Recommendation.PredictedLabel</strong>
                        </h5>

                        <div class="mt-3">
                            <h6>Confidence Scores:</h6>
                            @foreach (var mode in Model.Recommendation.ConfidenceByMode.OrderByDescending(x => x.Value))
                            {
                                var percentage = (mode.Value * 100).ToString("F1");
                                <div class="mb-2">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span>@mode.Key</span>
                                        <span>@percentage%</span>
                                    </div>
                                    <div class="progress" style="height: 1.5rem;">
                                        <div class="progress-bar" style="width: @percentage%">
                                            @percentage%
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>